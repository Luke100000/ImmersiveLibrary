<html lang="en">
<head>
    <title>Login</title>
    <link rel="stylesheet" href="/static/style.css">
    <meta name="referrer" content="no-referrer">
    <style>
        {% if verification_code %}
        body::before {
            content: "MCA verification code: {{ verification_code }}";
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            padding: 10px 16px;
            border-radius: 8px;
            background: rgba(0, 0, 0, 0.8);
            color: white;
            font-weight: bold;
            z-index: 1000;
        }
        {% endif %}
        body {
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        .container {
            display: flex;
            flex-flow: wrap;
            justify-content: center;
            align-items: center;
            text-align: center;
            flex: 1;
            width: 100%;
        }

        .container hr {
            width: 100%;
        }

        .chunk {
            color: black;
            font-family: Calibri, sans-serif;
            background-color: white;
            opacity: 95%;
            border-radius: 32px;
            padding: 16px 32px 32px 32px;
            box-shadow: 4px 6px 64px;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="chunk">
        {% if has_cookie_consent %}
            <h1>Authenticate</h1>
            Immersive Library uses your Google account as authentication.
            <br/>
            Only your Google user id is stored.
            <br/> <br/>

            <div id="g_id_onload"
                 data-client_id="{{ client_id }}"
                 data-login_uri="{{ login_uri }}"
                 data-ux_mode="redirect"
                 data-auto_prompt="false"
                 data-state='{{ state | tojson }}'>
            </div>

            <div class="g_id_signin"
                 data-type="standard"
                 data-size="large"
                 data-theme="filled_black"
                 data-text="sign_in_with"
                 data-shape="rectangular"
                 data-logo_alignment="left">
            </div>
            <p style="margin-top: 20px; font-size: 12px; color: #666;">Please read our <a href="/privacy">Privacy Notice</a> and <a href="/tos">Terms of Service</a> before continuing.</p>
            <script src="https://accounts.google.com/gsi/client" async defer></script>
        {% else %}
            <h1>Cookies and sign-in</h1>
            <p>We use a necessary cookie to keep you signed in and Google Sign-In to authenticate you.</p>
            <p>Please read our <a href="/privacy">Privacy Notice</a> and <a href="/tos">Terms of Service</a> before continuing.</p>
            <div class="consent-dialog__actions">
                <button id="reject-cookies" type="button" class="btn">Leave</button>
                <button id="accept-cookies" type="button" class="btn">Accept and continue</button>
            </div>
            <script>
                function setConsentCookie() {
                    const secure = window.location.protocol === 'https:' ? '; Secure' : '';
                    document.cookie = 'immersive_cookie_consent=yes; max-age=31536000; path=/; SameSite=Lax' + secure;
                }

                document.getElementById('accept-cookies').addEventListener('click', function () {
                    setConsentCookie();
                    window.location.reload();
                });
                document.getElementById('reject-cookies').addEventListener('click', function () {
                    window.location.replace('/');
                });
            </script>
        {% endif %}
    </div>
</div>
<footer>
    <a href="/privacy">Privacy Notice</a> •
    <a href="/tos">Terms of Service</a> •
    <a href="/contact">Contact</a>
</footer>
</body>
</html>
