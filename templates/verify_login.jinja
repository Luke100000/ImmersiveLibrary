<!DOCTYPE html>
<html lang="en">
<head>
    <title>Verify login</title>
    <link rel="stylesheet" href="/static/style.css">
    <meta name="referrer" content="no-referrer">
</head>
<body>
<div class="content-wrapper">
    <div class="card" style="max-width: 520px; margin: 10vh auto; padding: 24px;">
        <h1>Verify this login</h1>
        <p>Enter the verification code shown by the application that opened this page.</p>
        {% if error %}<p style="color: #ff6b6b;">{{ error }}</p>{% endif %}
        <form method="post" action="/v2/login/verify">
            <input type="hidden" name="request_id" value="{{ request_id }}">
            <label for="code">Verification code</label>
            <input id="code" name="code" type="text" autocomplete="one-time-code" required maxlength="9">
            <button class="btn" type="submit">Continue</button>
        </form>
    </div>
</div>
</body>
</html>
